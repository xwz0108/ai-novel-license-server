# ==========================================
# AI 小说创作助手 - License Server 环境变量配置
# ==========================================
# 复制此文件为 .env.local 并填写真实值
# Vercel 部署时请在项目设置 → Environment Variables 中配置

# ---------- 必填变量 ----------

# Upstash Redis 连接信息
# 获取方式：登录 https://upstash.com → 创建 Redis 数据库 → 复制 REST URL
UPSTASH_REDIS_URL=https://xxx-xxxxx.upstash.io
UPSTASH_REDIS_TOKEN=AYPxxxxx_xxxxx

# 爱发电（afdian.net）配置
# 获取方式：登录爱发电后台 → 设置 → API → 复制 user_id 和 api_key
AFDIAN_USER_ID=xxx
AFDIAN_API_KEY=xxx

# JWT / License 签名密钥（随便填一个长随机字符串）
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars

# 管理员密钥（用于调用 /api/generate 生成 License Key）
# 生成方式同上，调用时放在 body.adminKey 字段
ADMIN_KEY=replace_with_another_long_random_string

# ---------- 可选变量 ----------

# 允许的来源域名（CORS，多个用逗号分隔）
# 生产环境务必改成你的扩展 Chrome Web Store ID 或域名
ALLOWED_ORIGINS=chrome-extension://,https://xxddsses.com

# 日志级别（debug | info | warn | error）
LOG_LEVEL=info

# ---------- 爱发电 Plan ID 映射（在代码里配置） ----------
# 在 api/afdian-webhook.ts 的 getPlanConfig() 函数中配置
# 你的爱发电套餐 ID → License 类型映射
#
# 示例：
# 'plan_month_29_9'    → { type: 'subscription', days: 30 }
# 'plan_lifetime_199'  → { type: 'lifetime' }
# 'plan_credits_990'    → { type: 'credits', credits: 500 }
# 'plan_credits_2990'   → { type: 'credits', credits: 1800 }
#
# 请登录爱发电后台 → 赞助方案 → 查看方案 ID 并填写到 api/afdian-webhook.ts
